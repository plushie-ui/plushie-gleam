#!/usr/bin/env bash
#
# Run all CI checks locally. Exits on first failure.
#
# Usage:
#   just preflight     (handles deps, auto-detects renderer source)
#   ./bin/preflight    (direct invocation; also auto-detects renderer source)
#
# What it runs:
#   0. Renderer rebuild (only when PLUSHIE_RUST_SOURCE_PATH is set)
#   1. gleam format --check
#   2. gleam build (BEAM target)
#   3. gleam build --target=javascript (JS/WASM target)
#   4. gleam test (BEAM, mock backend)
#   5. gleam test (BEAM, headless backend)
#   6. gleam docs build
#
# Renderer freshness:
#   Tests exercise the real renderer binary, so a stale binary hides
#   real bugs and surfaces phantom ones. When PLUSHIE_RUST_SOURCE_PATH
#   is set to a plushie-rust checkout, step 0 rebuilds plushie-renderer
#   from source (release profile) and exports PLUSHIE_BINARY_PATH for
#   the rest of the run. When not set and ../plushie-rust exists, it
#   is auto-detected. Set PLUSHIE_RUST_SOURCE_PATH="" to force non-local.
#
# Test timeout:
#   PLUSHIE_TEST_TIMEOUT defaults to 2 (matching CI). Override to
#   relax on slow machines: PLUSHIE_TEST_TIMEOUT=5 ./bin/preflight

set -euo pipefail

export PLUSHIE_TEST_TIMEOUT="${PLUSHIE_TEST_TIMEOUT:-2}"

# Auto-detect plushie-rust source if not explicitly set.
# Set PLUSHIE_RUST_SOURCE_PATH="" to force non-local (skip auto-detect).
if [[ -z "${PLUSHIE_RUST_SOURCE_PATH+x}" ]]; then
    _candidate="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/../plushie-rust"
    if [[ -d "$_candidate" ]]; then
        PLUSHIE_RUST_SOURCE_PATH="$(cd "$_candidate" && pwd)"
        export PLUSHIE_RUST_SOURCE_PATH
    fi
    unset _candidate
fi

cyan='\033[0;36m'
green='\033[0;32m'
red='\033[0;31m'
reset='\033[0m'

run_step() {
    echo -e "${cyan}==> ${reset}$1"
    if eval "$1"; then
        echo -e "${green}    PASS${reset}"
    else
        echo -e "${red}    FAIL${reset}"
        exit 1
    fi
}

rebuild_renderer() {
    local source expanded manifest binary
    source="$1"
    expanded="$(cd "$source" 2>/dev/null && pwd || true)"
    if [ -z "$expanded" ]; then
        echo "    PLUSHIE_RUST_SOURCE_PATH=$source does not exist"
        return 1
    fi
    manifest="$expanded/Cargo.toml"
    if [ ! -f "$manifest" ]; then
        echo "    PLUSHIE_RUST_SOURCE_PATH=$source but no Cargo.toml at $manifest"
        return 1
    fi
    (cd "$expanded" && cargo build --release -p plushie-renderer) || return 1
    binary="$expanded/target/release/plushie-renderer"
    if [ ! -x "$binary" ]; then
        echo "    cargo build succeeded but $binary is missing"
        return 1
    fi
    export PLUSHIE_BINARY_PATH="$binary"
}

if [ -n "${PLUSHIE_RUST_SOURCE_PATH:-}" ]; then
    echo -e "${cyan}==> ${reset}cargo build --release -p plushie-renderer (PLUSHIE_RUST_SOURCE_PATH=$PLUSHIE_RUST_SOURCE_PATH)"
    if rebuild_renderer "$PLUSHIE_RUST_SOURCE_PATH"; then
        echo -e "${green}    PASS${reset} (PLUSHIE_BINARY_PATH=$PLUSHIE_BINARY_PATH)"
    else
        echo -e "${red}    FAIL${reset}"
        exit 1
    fi
fi

run_step "gleam format --check"

run_step "gleam build"

# JS target: check that source modules compile. Test files may
# have BEAM-only code (process.sleep, plushie.start, etc.) so we
# only fail if errors come from src/ files.
#
# Extract absolute file paths from Gleam diagnostic lines instead of
# matching the box-drawing character (┌─), which is multi-byte UTF-8
# and unreliable in non-UTF-8 locales. Also filter /packages/ so that
# warnings in third-party deps on fresh compiles do not trip the check.
echo -e "${cyan}==> ${reset}gleam build --target=javascript (source only)"
js_output=$(gleam build --target=javascript 2>&1 || true)
js_src_errors=$(echo "$js_output" \
    | grep -oE '/[^ ]+\.gleam:[0-9]+:[0-9]+' \
    | grep -v '/test/' \
    | grep -v '/packages/' \
    || true)
if [ -n "$js_src_errors" ]; then
    echo "$js_output" | grep -v '/test/' | grep -v '/packages/'
    echo -e "${red}    FAIL${reset}"
    exit 1
else
    echo -e "${green}    PASS${reset}"
fi

run_step "gleam test"

run_step "PLUSHIE_TEST_BACKEND=headless gleam test"

run_step "gleam docs build"

echo -e "\n${green}All checks passed.${reset}"
