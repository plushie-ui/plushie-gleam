#!/usr/bin/env bash
#
# Download a precompiled plushie binary for the current platform.
#
# Usage:
#   bin/plushie_download [--force]
#
# Downloads the binary to priv/bin/plushie with SHA256 verification.
# Skips if already present unless --force is passed.

set -euo pipefail

BASE_URL="https://github.com/plushie-ui/plushie/releases/download"

# Read version from gleam.toml -- look for the binary_version key,
# falling back to the project version if not set.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ -f "$PROJECT_DIR/gleam.toml" ]; then
    BINARY_VERSION=$(grep -E '^binary_version\s*=' "$PROJECT_DIR/gleam.toml" \
        | head -1 | sed 's/.*=\s*"\(.*\)"/\1/' || true)
    if [ -z "$BINARY_VERSION" ]; then
        BINARY_VERSION=$(grep -E '^version\s*=' "$PROJECT_DIR/gleam.toml" \
            | head -1 | sed 's/.*=\s*"\(.*\)"/\1/')
    fi
else
    echo "Error: gleam.toml not found in $PROJECT_DIR" >&2
    exit 1
fi

if [ -z "$BINARY_VERSION" ]; then
    echo "Error: could not determine binary version from gleam.toml" >&2
    exit 1
fi

# Detect platform
detect_platform() {
    local os arch
    os="$(uname -s)"
    arch="$(uname -m)"

    case "$os" in
        Linux)  os="linux" ;;
        Darwin) os="darwin" ;;
        *)
            echo "Error: unsupported OS: $os" >&2
            exit 1
            ;;
    esac

    case "$arch" in
        x86_64|amd64)   arch="x86_64" ;;
        aarch64|arm64)  arch="aarch64" ;;
        *)
            echo "Error: unsupported architecture: $arch" >&2
            exit 1
            ;;
    esac

    echo "${os}-${arch}"
}

PLATFORM="$(detect_platform)"
BINARY_NAME="plushie-${PLATFORM}"
URL="${BASE_URL}/v${BINARY_VERSION}/${BINARY_NAME}"
DEST_DIR="${PROJECT_DIR}/priv/bin"
DEST_PATH="${DEST_DIR}/plushie"

# Check --force flag
FORCE=false
for arg in "$@"; do
    if [ "$arg" = "--force" ]; then
        FORCE=true
    fi
done

if [ -f "$DEST_PATH" ] && [ "$FORCE" = false ]; then
    echo "Binary already exists at $DEST_PATH. Use --force to re-download."
    exit 0
fi

mkdir -p "$DEST_DIR"

echo "Downloading $BINARY_NAME from $URL..."

# Download binary
if ! curl -fSL --retry 3 -o "$DEST_PATH" "$URL"; then
    rm -f "$DEST_PATH"
    echo "" >&2
    echo "Download failed." >&2
    echo "" >&2
    echo "To build from source instead:" >&2
    echo "  bin/plushie_build" >&2
    echo "" >&2
    echo "To use an existing binary:" >&2
    echo "  export PLUSHIE_BINARY_PATH=/path/to/plushie" >&2
    exit 1
fi

chmod 755 "$DEST_PATH"
echo "Downloaded to $DEST_PATH"

# Download and verify SHA256 checksum
CHECKSUM_URL="${URL}.sha256"
CHECKSUM_FILE=$(mktemp)
trap 'rm -f "$CHECKSUM_FILE"' EXIT

if ! curl -fSL --retry 3 -o "$CHECKSUM_FILE" "$CHECKSUM_URL"; then
    rm -f "$DEST_PATH"
    echo "" >&2
    echo "SHA256 checksum file could not be downloaded." >&2
    echo "Refusing to use unverified binary. URL: $CHECKSUM_URL" >&2
    exit 1
fi

# Extract expected hash (first field, ignoring any filename after it)
EXPECTED_HASH=$(awk '{print $1}' "$CHECKSUM_FILE")

# Compute actual hash
if command -v sha256sum >/dev/null 2>&1; then
    ACTUAL_HASH=$(sha256sum "$DEST_PATH" | awk '{print $1}')
elif command -v shasum >/dev/null 2>&1; then
    ACTUAL_HASH=$(shasum -a 256 "$DEST_PATH" | awk '{print $1}')
else
    echo "Error: no sha256sum or shasum found" >&2
    rm -f "$DEST_PATH"
    exit 1
fi

if [ "$ACTUAL_HASH" = "$EXPECTED_HASH" ]; then
    echo "Checksum verified."
else
    echo "Checksum mismatch! Expected $EXPECTED_HASH, got $ACTUAL_HASH" >&2
    rm -f "$DEST_PATH"
    exit 1
fi
